{
  "name": "venice-solana-x402",
  "version": "0.1.0",
  "description": "Solana adapter for Venice AI x402 wallet auth: Sign-In-With-Solana, USDC top-up on Solana, and a reference autonomous agent that pays per call for Venice private inference and settles output on-chain.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "venice",
    "solana",
    "x402",
    "agent",
    "ai",
    "usdc"
  ],
  "bin": {
    "vsx-probe": "dist/probe.js",
    "vsx-agent": "dist/scripts/run-agent.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "probe": "tsx src/probe.ts",
    "probe:auth": "tsx src/probe-auth.ts",
    "agent": "tsx scripts/run-agent.ts",
    "keygen": "tsx scripts/keygen.ts"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "tweetnacl": "^1.0.3",
    "x402": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
