# Solana wallet the agent pays from (base58 secret key). Use a dedicated
# automation wallet, not your treasury. Fund it with a little SOL for gas and
# USDC to top up Venice.
SOLANA_SECRET_KEY=

# Solana RPC. A private RPC (Helius, Triton, QuickNode) is recommended over the
# public endpoint for anything real.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Venice model. Private and uncensored models suit autonomous agents:
# venice-uncensored, qwen3.6-35b-a3b-uncensored, gemma-4-26b-a4b-uncensored
VENICE_MODEL=venice-uncensored

# Tag prefixed to the on-chain memo the agent writes.
MEMO_TAG=vsx
